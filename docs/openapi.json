  "components" : {
    "schemas" : {
      "CreateTaskRequest" : {
        "required" : [ "assigneeUserIds", "dueDate", "schoolId", "title" ],
        "type" : "object",
        "properties" : {
          "title" : {
            "maxLength" : 120,
            "minLength" : 0,
            "type" : "string"
          },
          "description" : {
            "type" : "string"
          },
          "schoolId" : {
            "type" : "string",
            "format" : "uuid"
          },
          "classroomId" : {
            "type" : "string",
            "format" : "uuid"
          },
          "assigneeUserIds" : {
            "type" : "array",
            "items" : {
              "type" : "string",
              "format" : "uuid"
            }
          },
          "dueDate" : {
            "type" : "string",
            "format" : "date"
          },
          "dueTime" : {
            "$ref" : "#/components/schemas/LocalTime"
          },
          "status" : {
            "type" : "string",
            "enum" : [ "TODO", "IN_PROGRESS", "DONE" ]
          },
          "priority" : {
            "type" : "string",
            "enum" : [ "LOW", "MEDIUM", "HIGH" ]
          },
          "recurrence" : {
            "$ref" : "#/components/schemas/RecurrenceSpec"
          }
        }
      },
      "LocalTime" : {
        "type" : "object",
        "properties" : {
          "hour" : {
            "type" : "integer",
            "format" : "int32"
          },
          "minute" : {
            "type" : "integer",
            "format" : "int32"
          },
          "second" : {
            "type" : "integer",
            "format" : "int32"
          },
          "nano" : {
            "type" : "integer",
            "format" : "int32"
          }
        }
      },
      "RecurrenceSpec" : {
        "required" : [ "cycle", "untilDate" ],
        "type" : "object",
        "properties" : {
          "cycle" : {
            "type" : "string",
            "enum" : [ "DAILY", "WEEKLY", "MONTHLY" ]
          },
          "dueDayOfWeek" : {
            "type" : "integer",
            "format" : "int32"
          },
          "dueDayOfMonth" : {
            "type" : "integer",
            "format" : "int32"
          },
          "dueTime" : {
            "$ref" : "#/components/schemas/LocalTime"
          },
          "untilDate" : {
            "type" : "string",
            "format" : "date"
          }
        }
      },
      "TaskView" : {
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "string",
            "format" : "uuid"
          },
          "schoolId" : {
            "type" : "string",
            "format" : "uuid"
          },
          "orgId" : {
            "type" : "string",
            "format" : "uuid"
          },
          "classroomId" : {
            "type" : "string",
            "format" : "uuid"
          },
          "title" : {
            "type" : "string"
          },
          "description" : {
            "type" : "string"
          },
